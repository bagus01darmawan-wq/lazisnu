# ===========================================
# Environment Configuration Example
# Copy this file to .env and fill in values
# ===========================================

# Environment
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/lazisnu_db

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API Base URL
API_BASE_URL=http://localhost:3000

# WhatsApp Business API
# Get these from Meta Business Developer Portal
WA_BUSINESS_API_URL=https://graph.facebook.com/v18.0
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_ACCESS_TOKEN=your-whatsapp-access-token

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Cloudflare R2 (for file storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=lazisnu-files

# Google Play Integrity API
PLAY_INTEGRITY_KEY=your-play-integrity-api-key

# Internal API Key (for scheduler routes)
INTERNAL_API_KEY=your-internal-api-key