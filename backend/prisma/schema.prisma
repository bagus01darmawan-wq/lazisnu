// Prisma Schema - Lazisnu Collector App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum Types
enum UserRole {
  ADMIN_KECAMATAN
  ADMIN_RANTING
  BENDAHARA
  PETUGAS
}

enum CollectionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  POSTPONED
  REASSIGNED
}

// Geographic Hierarchy
model District {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(10)
  name       String   @db.VarChar(100)
  regionCode String   @map("region_code") @db.VarChar(5)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  branches      Branch[]
  users         User[]      @relation("DistrictUsers")
  collectionSummaries CollectionSummary[]
}

model Branch {
  id         String   @id @default(uuid()) @db.Uuid
  districtId String   @map("district_id") @db.Uuid
  code       String   @unique @db.VarChar(10)
  name       String   @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  district            District             @relation(fields: [districtId], references: [id], onDelete: Cascade)
  users               User[]               @relation("BranchUsers")
  officers            Officer[]
  cans                Can[]
  collectionSummaries CollectionSummary[]
}

// Users (Admin & Bendahara)
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  fullName     String   @map("full_name") @db.VarChar(100)
  phone        String   @unique @db.VarChar(20)
  role         UserRole
  districtId   String?  @map("district_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  district     District?  @relation("DistrictUsers", fields: [districtId], references: [id])
  branch       Branch?    @relation("BranchUsers", fields: [branchId], references: [id])
  officers     Officer[]
  activityLogs ActivityLog[]

  @@index([role])
  @@index([districtId])
  @@index([branchId])
}

// Officers (Petugas Lapangan)
model Officer {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  employeeCode  String   @unique @map("employee_code") @db.VarChar(20)
  fullName      String   @map("full_name") @db.VarChar(100)
  phone         String   @unique @db.VarChar(20)
  photoUrl      String?  @map("photo_url") @db.VarChar(500)
  districtId    String   @map("district_id") @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  assignedZone  String?  @map("assigned_zone") @db.VarChar(100)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  district     District     @relation(fields: [districtId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  assignments  Assignment[]
  collections  Collection[]
  syncQueues   SyncQueue[]

  @@index([districtId])
  @@index([branchId])
}

// Can (Kaleng/Kotak Infaq)
model Can {
  id              String   @id @default(uuid()) @db.Uuid
  qrCode          String   @unique @map("qr_code") @db.VarChar(50)
  branchId        String   @map("branch_id") @db.Uuid
  ownerName       String   @map("owner_name") @db.VarChar(100)
  ownerPhone      String   @map("owner_phone") @db.VarChar(20)
  ownerAddress    String   @map("owner_address") @db.Text
  ownerWhatsapp   String?  @map("owner_whatsapp") @db.VarChar(20)
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  locationNotes   String?  @map("location_notes") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  lastCollectedAt DateTime? @map("last_collected_at")
  totalCollected  Decimal  @default(0) @map("total_collected") @db.Decimal(15, 2)
  collectionCount Int      @default(0) @map("collection_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  branch       Branch       @relation(fields: [branchId], references: [id])
  assignments  Assignment[]
  collections  Collection[]

  @@index([qrCode])
  @@index([branchId])
  @@index([ownerPhone])
  @@index([isActive])
}

// Assignment (Penugasan)
model Assignment {
  id               String           @id @default(uuid()) @db.Uuid
  canId            String           @map("can_id") @db.Uuid
  officerId        String           @map("officer_id") @db.Uuid
  backupOfficerId  String?          @map("backup_officer_id") @db.Uuid
  periodYear       Int              @map("period_year")
  periodMonth      Int              @map("period_month")
  status           AssignmentStatus @default(ACTIVE)
  assignedAt       DateTime         @default(now()) @map("assigned_at")
  completedAt      DateTime?        @map("completed_at")
  notes            String?          @db.Text
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  can             Can          @relation(fields: [canId], references: [id], onDelete: Cascade)
  officer         Officer      @relation("PrimaryOfficer", fields: [officerId], references: [id])
  backupOfficer   Officer?     @relation("BackupOfficer", fields: [backupOfficerId], references: [id])
  collections     Collection[]

  @@unique([canId, officerId, periodYear, periodMonth])
  @@index([canId])
  @@index([officerId])
  @@index([periodYear, periodMonth])
  @@index([status])
}

// Collection (Penjemputan)
model Collection {
  id                 String           @id @default(uuid()) @db.Uuid
  assignmentId       String           @map("assignment_id") @db.Uuid
  canId              String           @map("can_id") @db.Uuid
  officerId          String           @map("officer_id") @db.Uuid
  amount             Decimal          @db.Decimal(15, 2)
  paymentMethod      PaymentMethod    @default(CASH) @map("payment_method")
  transferReceiptUrl String?          @map("transfer_receipt_url") @db.VarChar(500)
  collectedAt        DateTime         @map("collected_at")
  submittedAt        DateTime?        @map("submitted_at")
  syncedAt           DateTime?        @map("synced_at")
  syncStatus         CollectionStatus @default(PENDING) @map("sync_status")
  serverTimestamp    DateTime?        @map("server_timestamp")
  deviceInfo         Json?            @map("device_info")
  latitude           Decimal?         @db.Decimal(10, 8)
  longitude          Decimal?        @db.Decimal(11, 8)
  offlineId          String?          @map("offline_id") @db.VarChar(100)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  assignment     Assignment     @relation(fields: [assignmentId], references: [id])
  can            Can            @relation(fields: [canId], references: [id])
  officer        Officer        @relation(fields: [officerId], references: [id])
  notifications  Notification[]
  activityLogs   ActivityLog[]

  @@index([assignmentId])
  @@index([canId])
  @@index([officerId])
  @@index([collectedAt])
  @@index([syncStatus])
  @@index([offlineId])
}

// Notification (WhatsApp Logs)
model Notification {
  id              String    @id @default(uuid()) @db.Uuid
  collectionId    String?   @map("collection_id") @db.Uuid
  recipientPhone  String    @map("recipient_phone") @db.VarChar(20)
  recipientName   String?   @map("recipient_name") @db.VarChar(100)
  messageTemplate String?   @map("message_template") @db.VarChar(50)
  messageContent  String    @map("message_content") @db.Text
  status          String    @default("PENDING")
  sentAt          DateTime? @map("sent_at")
  errorMessage    String?   @map("error_message") @db.Text
  waMessageId     String?   @map("wa_message_id") @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  collection Collection? @relation(fields: [collectionId], references: [id])

  @@index([collectionId])
  @@index([recipientPhone])
  @@index([status])
  @@index([sentAt])
}

// Activity Logs (Audit Trail)
model ActivityLog {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  officerId  String?   @map("officer_id") @db.Uuid
  actionType String    @map("action_type") @db.VarChar(50)
  entityType String?   @map("entity_type") @db.VarChar(50)
  entityId   String?   @map("entity_id") @db.Uuid
  oldData    Json?     @map("old_data")
  newData    Json?     @map("new_data")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User?       @relation(fields: [userId], references: [id])
  collection Collection?  @relation(fields: [entityId], references: [id])

  @@index([userId])
  @@index([officerId])
  @@index([actionType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// Sync Queue (for offline support)
model SyncQueue {
  id          String    @id @default(uuid()) @db.Uuid
  officerId   String    @map("officer_id") @db.Uuid
  entityType  String    @map("entity_type") @db.VarChar(50)
  entityData  Json      @map("entity_data")
  localId     String    @map("local_id") @db.VarChar(100)
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  lastError   String?   @map("last_error") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  officer Officer @relation(fields: [officerId], references: [id])

  @@index([officerId])
  @@index([status])
  @@index([localId])
}

// Collection Summaries (Materialized for performance)
model CollectionSummary {
  id            String   @id @default(uuid()) @db.Uuid
  periodYear    Int      @map("period_year")
  periodMonth   Int      @map("period_month")
  districtId    String?  @map("district_id") @db.Uuid
  branchId      String?  @map("branch_id") @db.Uuid
  officerId     String?  @map("officer_id") @db.Uuid
  totalAmount   Decimal  @default(0) @map("total_amount") @db.Decimal(15, 2)
  collectionCount Int    @default(0) @map("collection_count")
  cashCount     Int      @default(0) @map("cash_count")
  cashAmount    Decimal  @default(0) @map("cash_amount") @db.Decimal(15, 2)
  transferCount Int      @default(0) @map("transfer_count")
  transferAmount Decimal @default(0) @map("transfer_amount") @db.Decimal(15, 2)
  calculatedAt  DateTime @default(now()) @map("calculated_at")

  district District? @relation(fields: [districtId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  officer  Officer?   @relation(fields: [officerId], references: [id])

  @@unique([periodYear, periodMonth, districtId, branchId, officerId])
  @@index([periodYear, periodMonth])
  @@index([districtId])
  @@index([branchId])
  @@index([officerId])
}